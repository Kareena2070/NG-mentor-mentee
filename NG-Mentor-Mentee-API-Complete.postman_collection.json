  "item": [
    {
      "name": "Setup - Create Test Users",
      "item": [
        {
          "name": "Register Mentee User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    const emailMatch = pm.request.body.raw.match(/\"email\"\\s*:\\s*\"([^\"]+)\"/);",
                  "    if (emailMatch) {",
                  "        pm.environment.set('mentee_email', emailMatch[1]);",
                  "        pm.environment.set('mentee_password', 'Password123!');",
                  "    }",
                  "    pm.test('✅ Register Mentee - Success (201)', function () {",
                  "        pm.expect(pm.response.code).to.equal(201);",
                  "        pm.expect(data.success).to.equal(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Mentee {{$timestamp}}\",\n  \"email\": \"mentee{{$timestamp}}@test.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"mentee\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Register Mentor User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    const emailMatch = pm.request.body.raw.match(/\"email\"\\s*:\\s*\"([^\"]+)\"/);",
                  "    if (emailMatch) {",
                  "        pm.environment.set('mentor_email', emailMatch[1]);",
                  "        pm.environment.set('mentor_password', 'Password123!');",
                  "    }",
                  "    if (data.token) {",
                  "        pm.environment.set('mentor_token', data.token);",
                  "    }",
                  "    if (data.user && data.user.id) {",
                  "        pm.environment.set('mentor_id', data.user.id);",
                  "    }",
                  "    pm.test('✅ Register Mentor - Success (201)', function () {",
                  "        pm.expect(pm.response.code).to.equal(201);",
                  "        pm.expect(data.success).to.equal(true);",
                  "    });",
                  "} else {",
                  "    pm.test('⚠️  Mentor Registration - Status: ' + pm.response.code, function () {",
                  "        pm.expect(true).to.equal(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Mentor {{$timestamp}}\",\n  \"email\": \"mentor{{$timestamp}}@test.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"mentor\",\n  \"menteeEmail\": \"mentee@test.com\",\n  \"expertise\": [\"JavaScript\", \"React\", \"Node.js\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login as Mentee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.environment.set('mentee_token', data.token);",
                  "    pm.environment.set('mentee_id', data.user.id);",
                  "    pm.test('✅ Login Mentee - Success (200), Token Saved', function () {",
                  "        pm.expect(pm.response.code).to.equal(200);",
                  "        pm.expect(data.token).to.exist;",
                  "        pm.expect(data.user.id).to.exist;",
                  "    });",
                  "} else {",
                  "    pm.test('❌ Login Mentee Failed ' + pm.response.code, function () {",
                  "        console.log('Response:', pm.response.json());",
                  "        pm.expect(pm.response.code).to.equal(200);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{mentee_email}}\",\n  \"password\": \"{{mentee_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login as Mentor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
